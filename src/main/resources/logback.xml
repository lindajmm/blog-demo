<?xml version="1.0" encoding="UTF-8"?>
<configuration>

<!-- ==================== 变量定义 ==================== -->
<!-- 日志文件存放路径 -->
<property name="LOG_PATH" value="logs" />
<!-- 日志文件名称 -->
<property name="LOG_FILE" value="blog-demo" />
<!-- 日志格式 -->
<property name="LOG_PATTERN" value="%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{50} - %msg%n" />
<!-- 彩色日志格式（控制台专用） -->
<property name="CONSOLE_LOG_PATTERN" value="%d{yyyy-MM-dd HH:mm:ss.SSS} %highlight(%-5level) [%thread] %cyan(%logger{50}) - %msg%n" />

<!-- ==================== 控制台输出 ==================== -->
<appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
<encoder>
<pattern>${CONSOLE_LOG_PATTERN}</pattern>
<charset>UTF-8</charset>
</encoder>
</appender>

<!-- ==================== 文件输出（所有日志） ==================== -->
<appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
<!-- 正在记录的日志文件 -->
<file>${LOG_PATH}/${LOG_FILE}.log</file>

<!-- 滚动策略：按时间和大小 -->
<rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
<!-- 日志文件名格式 -->
<fileNamePattern>${LOG_PATH}/${LOG_FILE}.%d{yyyy-MM-dd}.%i.log</fileNamePattern>

<!-- 保留天数 -->
<maxHistory>30</maxHistory>

<!-- 单个文件最大大小（触发滚动） -->
<timeBasedFileNamingAndTriggeringPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedFNATP">
<maxFileSize>10MB</maxFileSize>
</timeBasedFileNamingAndTriggeringPolicy>
</rollingPolicy>

<!-- 日志格式 -->
<encoder>
<pattern>${LOG_PATTERN}</pattern>
<charset>UTF-8</charset>
</encoder>
</appender>

<!-- ==================== 错误日志单独输出 ==================== -->
<appender name="ERROR_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
<!-- 只记录 ERROR 级别 -->
<filter class="ch.qos.logback.classic.filter.LevelFilter">
<level>ERROR</level>
<onMatch>ACCEPT</onMatch>
<onMismatch>DENY</onMismatch>
</filter>

<file>${LOG_PATH}/${LOG_FILE}-error.log</file>

<rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
<fileNamePattern>${LOG_PATH}/${LOG_FILE}-error.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
<maxHistory>30</maxHistory>
<timeBasedFileNamingAndTriggeringPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedFNATP">
<maxFileSize>10MB</maxFileSize>
</timeBasedFileNamingAndTriggeringPolicy>
</rollingPolicy>

<encoder>
<pattern>${LOG_PATTERN}</pattern>
<charset>UTF-8</charset>
</encoder>
</appender>

<!-- ==================== SQL 日志单独输出（调试用） ==================== -->
<appender name="SQL_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
<file>${LOG_PATH}/sql.log</file>

<rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
<fileNamePattern>${LOG_PATH}/sql.%d{yyyy-MM-dd}.log</fileNamePattern>
<maxHistory>7</maxHistory>
</rollingPolicy>

<encoder>
<pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{100} - %msg%n</pattern>
<charset>UTF-8</charset>
</encoder>
</appender>

<!-- ==================== 日志级别配置 ==================== -->

<!-- 项目日志 -->
<logger name="com.example.blog_demo" level="DEBUG" />
<logger name="com.example.blog_demo.mapper" level="DEBUG" additivity="false">
<appender-ref ref="CONSOLE" />
<appender-ref ref="FILE" />
<appender-ref ref="SQL_FILE" />
</logger>

<!-- MyBatis SQL 日志 -->
<logger name="org.mybatis" level="INFO" />

<!-- Spring 框架日志（减少输出） -->
<logger name="org.springframework" level="INFO" />
<logger name="org.springframework.web" level="INFO" />

<!-- 连接池日志 -->
<logger name="com.zaxxer.hikari" level="INFO" />

<!-- Tomcat 日志 -->
<logger name="org.apache.catalina" level="INFO" />
<logger name="org.apache.tomcat" level="INFO" />

<!-- ==================== 根日志级别 ==================== -->
<root level="INFO">
<appender-ref ref="CONSOLE" />
<appender-ref ref="FILE" />
<appender-ref ref="ERROR_FILE" />
</root>

</configuration>